# ── CafeBoard Environment Variables ────────────────────────────
# Copy this file to .env and adjust values for your environment.

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=cafeboard
POSTGRES_USER=cafeboard
POSTGRES_PASSWORD=cafeboard_secret
DB_PORT=5432

# ── Backend ───────────────────────────────────────────────────
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://cafeboard:cafeboard_secret@db:5432/cafeboard
SECRET_KEY=change-me-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

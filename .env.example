# Переменные окружения для CafeBoard
# Скопируйте в .env и заполните значениями

# ──────────────────────────────────────────────
# База данных
# Для разработки (SQLite):
#   DATABASE_URL=sqlite:///./data/cafeboard.db
# Для продакшена (PostgreSQL):
#   DATABASE_URL=postgresql://cafeboard:cafeboard-secret@db:5432/cafeboard
# ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/cafeboard.db

# ──────────────────────────────────────────────
# PostgreSQL (используется если DATABASE_URL = postgresql://...)
# ──────────────────────────────────────────────
POSTGRES_DB=cafeboard
POSTGRES_USER=cafeboard
POSTGRES_PASSWORD=cafeboard-secret

# ──────────────────────────────────────────────
# Безопасность
# ──────────────────────────────────────────────
# Секретный ключ для JWT-токенов (сгенерируйте: openssl rand -hex 32)
SECRET_KEY=dev-secret-key-change-in-production

# ──────────────────────────────────────────────
# CORS — разрешённые источники (через запятую)
# ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ──────────────────────────────────────────────
# Frontend — URL бэкенда для Vite
# ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
